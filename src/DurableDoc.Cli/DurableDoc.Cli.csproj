    <PackageTitle>durable-doc</PackageTitle>
    <Description>CLI tool for analyzing Azure Durable Functions orchestrations and generating workflow diagrams.</Description>
    <Authors>OpenAI</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\DurableDoc.Analysis\DurableDoc.Analysis.csproj" />
    <ProjectReference Include="..\DurableDoc.Configuration\DurableDoc.Configuration.csproj" />
    <ProjectReference Include="..\DurableDoc.Dashboard\DurableDoc.Dashboard.csproj" />
    <ProjectReference Include="..\DurableDoc.Rendering.Mermaid\DurableDoc.Rendering.Mermaid.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="System.CommandLine" Version="2.0.0-beta4.22272.1" />
  </ItemGroup>
</Project>
