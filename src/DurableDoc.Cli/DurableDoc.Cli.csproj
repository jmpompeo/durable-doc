<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>DurableDoc.Cli</RootNamespace>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>durable-doc</ToolCommandName>
    <PackageId>durable-doc</PackageId>
    <Version>0.1.0</Version>
